{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LessAI",
  "version": "0.1.0",
  "identifier": "com.lessai.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LessAI",
        "width": 1320,
        "height": 780,
        "minWidth": 980,
        "minHeight": 640,
        "center": true,
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/installer-header.bmp",
        "sidebarImage": "icons/installer-sidebar.bmp"
      },
      "wix": {
        "bannerPath": "icons/installer-wix-banner.bmp",
        "dialogImagePath": "icons/installer-wix-dialog.bmp"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/GTJasonMK/lessAI/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJGRDMzOUQ4QUM2OTk4RTgKUldUb21HbXMyRG5UTHc5R1l2VXZTdEV1b3ZPNHcwWk1xS1k0Z1NoY0RvTy96V1lCWnJEbUZocFgK"
    }
  }
}
