# ------------------------------
# LessAI (.gitignore)
# ------------------------------

# Dependencies
node_modules/
.pnpm-store/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build output
dist/
.vite/
*.tsbuildinfo

# Tauri / Rust build artifacts
src-tauri/target/
src-tauri/.tauri/
src-tauri/tauri.release.conf.json

# Release / CI temp outputs
artifacts/
release-assets/

# Tauri updater signing keys (never commit)
src-tauri/updater.key
src-tauri/updater.key.pub

# Env / local config
.env
.env.*

# OS files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# IDE / editors
.vscode/
.idea/
*.iml
*.swp
*.swo

# AI / agent tooling (local only)
.claude/
.codex
.codex/
.superpowers/

# Temp / patch leftovers
.tmp/
*.tmp
*.temp
*.bak
*.orig
*.rej
