{
  "name": "lessai",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 1420",
    "dev:demo": "vite --mode demo --host 0.0.0.0 --port 1421",
    "build": "pnpm run build:desktop",
    "build:desktop": "tsc && vite build",
    "build:demo": "tsc && vite build --mode demo",
    "preview": "vite preview",
    "preview:demo": "pnpm run build:demo && vite preview --host 0.0.0.0 --port 4173 --strictPort",
    "icons:generate": "pnpm exec tauri icon src-tauri/icons/lessai-logo.svg",
    "tauri": "pnpm exec tauri",
    "tauri:dev": "pnpm exec tauri dev --config src-tauri/tauri.dev.conf.json",
    "tauri:build": "pnpm exec tauri build",
    "typecheck": "tsc --noEmit",
    "placeholders:generate": "node scripts/generate-placeholder-labels.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-log": "^2.0.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "lucide-react": "^0.542.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.2",
    "typescript": "^5.9.2",
    "vite": "^7.1.2"
  }
}
