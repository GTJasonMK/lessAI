<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<w:document
  xmlns:w="http://schemas.openxmlformats.org/wordprocessingml/2006/main"
  xmlns:r="http://schemas.openxmlformats.org/officeDocument/2006/relationships"
  xmlns:m="http://schemas.openxmlformats.org/officeDocument/2006/math"
  xmlns:wp="http://schemas.openxmlformats.org/drawingml/2006/wordprocessingDrawing"
  xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main"
  xmlns:pic="http://schemas.openxmlformats.org/drawingml/2006/picture"
  xmlns:v="urn:schemas-microsoft-com:vml">
  <w:body>
    <w:p>
      <w:pPr>
        <w:pStyle w:val="Title" />
      </w:pPr>
      <w:r><w:t>LessAI 综合测试（DOCX）</w:t></w:r>
    </w:p>

    <w:p>
      <w:pPr>
        <w:pStyle w:val="Subtitle" />
      </w:pPr>
      <w:r><w:t>用于验证标题、正文、列表、超链接、样式、公式、占位符和安全写回</w:t></w:r>
    </w:p>

    <w:p>
      <w:pPr><w:pStyle w:val="Heading1" /></w:pPr>
      <w:r><w:t>1. 文档说明与测试目标</w:t></w:r>
    </w:p>

    <w:p>
      <w:r><w:t>这是一份 docx 综合样本，目标是让你在一个文件里同时检查导入、分块、审阅、锁定占位和写回。</w:t></w:r>
      <w:r><w:t>建议分别切换段落、整句、小句三种粒度，然后观察正文和锁定区是否边界清晰。</w:t></w:r>
    </w:p>

    <w:p>
      <w:pPr><w:pStyle w:val="Heading1" /></w:pPr>
      <w:r><w:t>2. 标题层级与普通段落</w:t></w:r>
    </w:p>

    <w:p>
      <w:pPr><w:pStyle w:val="Heading2" /></w:pPr>
      <w:r><w:t>2.1 小标题样式</w:t></w:r>
    </w:p>

    <w:p>
      <w:r><w:t>这一段是普通正文。它包含小数 3.14、日期 2026-04-09、版本号 v2.3.7。</w:t></w:r>
      <w:r><w:t>整句模式下，句末标点应成为主要边界；段落模式下，这一整段应保持连续。</w:t></w:r>
    </w:p>

    <w:p>
      <w:r><w:t>下一段继续模拟报告正文：先描述背景，再给出判断，最后补一句限制条件。</w:t></w:r>
      <w:r><w:t>这里还包含中英混排，例如 Dr. Wang 和 U.S.A.。</w:t></w:r>
    </w:p>

    <w:p></w:p>

    <w:p>
      <w:pPr><w:pStyle w:val="Heading1" /></w:pPr>
      <w:r><w:t>3. 标点边界与数字边界</w:t></w:r>
    </w:p>

    <w:p>
      <w:r><w:t>这一段包含 2,718.28、No. 5、Sec. 4.1、Eq. (3) 和 2025-12-31。</w:t></w:r>
      <w:r><w:t>它们不应因为句点、逗号或短横线而被错误切成无意义的小块。</w:t></w:r>
    </w:p>

    <w:p>
      <w:pPr><w:pStyle w:val="Heading1" /></w:pPr>
      <w:r><w:t>4. 列表与段内换行</w:t></w:r>
    </w:p>

    <w:p>
      <w:pPr>
        <w:numPr>
          <w:ilvl w:val="0" />
          <w:numId w:val="1" />
        </w:numPr>
      </w:pPr>
      <w:r><w:t>列表项 A：包含括号（例如 A1、A2、A3），用于观察小句边界。</w:t></w:r>
    </w:p>

    <w:p>
      <w:pPr>
        <w:numPr>
          <w:ilvl w:val="0" />
          <w:numId w:val="1" />
        </w:numPr>
      </w:pPr>
      <w:r><w:t>列表项 B：包含命令 token cargo fmt --check，不应被拆坏。</w:t></w:r>
    </w:p>

    <w:p>
      <w:r><w:t>这一段包含一个 Tab：</w:t></w:r>
      <w:r><w:tab /></w:r>
      <w:r><w:t>Tab 后面还有文字；以及一个手动换行：</w:t></w:r>
      <w:r><w:br /></w:r>
      <w:r><w:t>换行后的文字仍属于同一段落。</w:t></w:r>
    </w:p>

    <w:p>
      <w:pPr><w:pStyle w:val="Heading1" /></w:pPr>
      <w:r><w:t>5. 链接与可读正文</w:t></w:r>
    </w:p>

    <w:p>
      <w:r><w:t>这一段包含一个超链接：</w:t></w:r>
      <w:hyperlink r:id="rId1">
        <w:r><w:t>官方说明页</w:t></w:r>
      </w:hyperlink>
      <w:r><w:t>。导入后应显示为可读正文，并保留目标 URL 元数据。</w:t></w:r>
    </w:p>

    <w:p>
      <w:r><w:t>这里再放一个普通文本链接 https://example.com/plain-url，以及邮箱 qa@example.com。</w:t></w:r>
    </w:p>

    <w:p>
      <w:pPr><w:pStyle w:val="Heading1" /></w:pPr>
      <w:r><w:t>6. 行内强调与常见样式</w:t></w:r>
    </w:p>

    <w:p>
      <w:r><w:t>这一句先放普通文本，然后放</w:t></w:r>
      <w:r>
        <w:rPr><w:b /></w:rPr>
        <w:t>加粗文本</w:t>
      </w:r>
      <w:r><w:t>、</w:t></w:r>
      <w:r>
        <w:rPr><w:i /></w:rPr>
        <w:t>斜体文本</w:t>
      </w:r>
      <w:r><w:t>、</w:t></w:r>
      <w:r>
        <w:rPr><w:u w:val="single" /></w:rPr>
        <w:t>下划线文本</w:t>
      </w:r>
      <w:r><w:t>，用于检查样式保留。</w:t></w:r>
    </w:p>

    <w:p>
      <w:pPr><w:pStyle w:val="Heading1" /></w:pPr>
      <w:r><w:t>7. 代码、命令与原样内容</w:t></w:r>
    </w:p>

    <w:p>
      <w:r><w:t>这一段包含命令 pnpm install、pnpm run tauri:dev、cargo test，以及路径 /src-tauri/src/adapters/docx.rs。</w:t></w:r>
      <w:r><w:t>它们都应保持可读，不应在写回时丢失短横线或斜杠。</w:t></w:r>
    </w:p>

    <w:p>
      <w:pPr><w:pStyle w:val="Heading1" /></w:pPr>
      <w:r><w:t>8. 数学与公式相关内容</w:t></w:r>
    </w:p>

    <w:p>
      <w:r><w:t>这段先放普通正文，再插入公式 </w:t></w:r>
      <m:oMath>
        <m:r><m:t>E=mc^2</m:t></m:r>
      </m:oMath>
      <w:r><w:t>，然后继续写结论。公式应显示但保持锁定。</w:t></w:r>
    </w:p>

    <w:p>
      <w:r><w:t>这里再放一个分页符占位，上文</w:t></w:r>
      <w:r><w:br w:type="page" /></w:r>
      <w:r><w:t>下文。分页符应作为锁定占位存在，不允许被改写。</w:t></w:r>
    </w:p>

    <w:p>
      <w:pPr><w:pStyle w:val="Heading1" /></w:pPr>
      <w:r><w:t>9. 表格与非正文结构</w:t></w:r>
    </w:p>

    <w:tbl>
      <w:tr>
        <w:tc><w:p><w:r><w:t>项目</w:t></w:r></w:p></w:tc>
        <w:tc><w:p><w:r><w:t>期望行为</w:t></w:r></w:p></w:tc>
        <w:tc><w:p><w:r><w:t>备注</w:t></w:r></w:p></w:tc>
      </w:tr>
      <w:tr>
        <w:tc><w:p><w:r><w:t>标题</w:t></w:r></w:p></w:tc>
        <w:tc><w:p><w:r><w:t>默认锁定</w:t></w:r></w:p></w:tc>
        <w:tc><w:p><w:r><w:t>可按设置切换</w:t></w:r></w:p></w:tc>
      </w:tr>
      <w:tr>
        <w:tc><w:p><w:r><w:t>链接</w:t></w:r></w:p></w:tc>
        <w:tc><w:p><w:r><w:t>显示文本可见</w:t></w:r></w:p></w:tc>
        <w:tc><w:p><w:r><w:t>目标 URL 保留</w:t></w:r></w:p></w:tc>
      </w:tr>
    </w:tbl>

    <w:sdt>
      <w:sdtContent>
        <w:p><w:r><w:t>目录条目不应进入可编辑正文</w:t></w:r></w:p>
      </w:sdtContent>
    </w:sdt>

    <w:p>
      <w:pPr><w:pStyle w:val="Heading1" /></w:pPr>
      <w:r><w:t>10. 混合段落与锁定区穿插</w:t></w:r>
    </w:p>

    <w:p>
      <w:r><w:t>这一段先写普通正文，再插入图片占位对象</w:t></w:r>
      <w:r>
        <w:drawing>
          <wp:inline>
            <a:graphic>
              <a:graphicData>
                <pic:pic />
              </a:graphicData>
            </a:graphic>
          </wp:inline>
        </w:drawing>
      </w:r>
      <w:r><w:t>，然后继续正文，再插入文本框占位对象</w:t></w:r>
      <w:r>
        <w:pict>
          <v:textbox>
            <w:txbxContent>
              <w:p><w:r><w:t>文本框里的说明文字不应进入可编辑正文</w:t></w:r></w:p>
            </w:txbxContent>
          </v:textbox>
        </w:pict>
      </w:r>
      <w:r><w:t>，最后补一句收尾说明。</w:t></w:r>
    </w:p>

    <w:p>
      <w:r><w:t>这一句把链接、公式和普通文本再次混排，便于观察锁定区是否打断阅读。</w:t></w:r>
    </w:p>

    <w:p>
      <w:pPr><w:pStyle w:val="Heading1" /></w:pPr>
      <w:r><w:t>11. 写回敏感区</w:t></w:r>
    </w:p>

    <w:p>
      <w:r><w:t>请只做一种最小修改：把一个逗号改成分号，或者在下一句前插入空行，或者把问号改成感叹号。</w:t></w:r>
    </w:p>

    <w:p><w:r><w:t>短句 A，用来观察局部 diff。</w:t></w:r></w:p>
    <w:p><w:r><w:t>短句 B，用来观察空行边界。</w:t></w:r></w:p>
    <w:p><w:r><w:t>短句 C？</w:t></w:r></w:p>

    <w:p>
      <w:pPr><w:pStyle w:val="Heading1" /></w:pPr>
      <w:r><w:t>12. 长段落与压力观察区</w:t></w:r>
    </w:p>

    <w:p>
      <w:r><w:t>这一整段故意写得比较长，用来观察 docx 正文在复杂混排场景下的稳定性：它同时包含中文说明、English phrases、数字 0.618、日期 2024-2026、版本号 v3.1.4、超链接显示文本、普通文本 URL、路径、命令 token、括号（例如这里的补充说明）、以及一句收尾判断；段落模式应优先保证整体可读，整句模式应主要在真正句末切开，小句模式则可以更细，但任何一种模式都不应把短链接、短数字或相邻样式块拆成大量无意义的小块。</w:t></w:r>
    </w:p>

    <w:sectPr />
  </w:body>
</w:document>
